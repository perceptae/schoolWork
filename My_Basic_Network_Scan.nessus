box&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Clipboard Seamless&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_prefer_local_cursor type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Prefer Local Cursor&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_translate_shortcuts type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Translate keyboard shortcuts&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_enable_webrtc type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Enable WebRTC UDP Transit&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_enable_webp type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Enable WebP Compression&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_enable_perf_stats type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Enable Performance Stats&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input type=checkbox id=noVNC_setting_pointer_lock&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Enable Pointer Lock&lt;/span&gt;&lt;/label&gt;&lt;/li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_enable_ime type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;IME Input Mode&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_virtual_keyboard_visible type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Show Virtual Keyboard Control&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_toggle_control_panel type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Toggle Control Panel via Keystrokes&lt;/span&gt;&lt;/label&gt;&lt;li class=noVNC_hidden&gt;&lt;label for=noVNC_setting_idle_disconnect&gt;Idle Timeout:&lt;/label&gt; &lt;select id=noVNC_setting_idle_disconnect name=vncIdleDisconnect&gt;&lt;option value=10&gt;10&lt;option value=20&gt;20&lt;option value=30&gt;30&lt;option value=60&gt;60&lt;/select&gt;&lt;li&gt;&lt;hr&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_view_clip type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Clip to Window&lt;/span&gt;&lt;/label&gt;&lt;li&gt;&lt;label for=noVNC_setting_resize&gt;Scaling Mode:&lt;/label&gt; &lt;select id=noVNC_setting_resize name=vncResize&gt;&lt;option value=off&gt;None&lt;option value=scale&gt;Local Scaling&lt;option value=remote&gt;Remote Resizing&lt;/select&gt;&lt;li&gt;&lt;hr&gt;&lt;li&gt;&lt;div class=noVNC_expander&gt;Keyboard Shortcuts&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;label class=switch&gt;&lt;input id=noVNC_setting_toggle_control_panel type=checkbox&gt; &lt;span class=&quot;slider round&quot;&gt;&lt;/span&gt; &lt;span class=slider-label&gt;Enable KasmVNC Keyboard Shortcuts&lt;/span&gt;&lt;/label&gt;&lt;li&gt;Ctrl+Shift+&lt;li&gt;1 - Toggle Control Panel&lt;li&gt;2 - Toggle Game Pointer Mode&lt;li&gt;3 - Toggle Pointer Lock&lt;/ul&gt;&lt;/div&gt;&lt;li&gt;&lt;hr&gt;&lt;li&gt;&lt;div class=noVNC_expander&gt;Stream Quality&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;label for=noVNC_setting_video_quality&gt;Preset Modes:&lt;/label&gt; &lt;select id=noVNC_setting_video_quality name=vncVideoQuality&gt;&lt;/select&gt;&lt;li&gt;&lt;label for=noVNC_setting_anti_aliasing&gt;Anti-Aliasing:&lt;/label&gt; &lt;select id=noVNC_setting_anti_aliasing name=vncAntiAliasing&gt;&lt;option value=0&gt;Auto Dynamic&lt;option value=1&gt;On&lt;option value=2&gt;Off&lt;/select&gt;&lt;li style=display:none&gt;&lt;label for=noVNC_setting_quality&gt;Quality:&lt;/label&gt; &lt;input id=noVNC_setting_quality type=range min=0 max=9 value=6&gt;&lt;li&gt;&lt;label for=noVNC_setting_dynamic_quality_min&gt;Dynamic Quality Min:&lt;/label&gt; &lt;input id=noVNC_setting_dynamic_quality_min type=range min=0 max=9 value=3 onchange=&quot;noVNC_setting_dynamic_quality_min_output.value=value&quot;&gt;&lt;output id=noVNC_setting_dynamic_quality_min_output&gt;3&lt;/output&gt;&lt;li&gt;&lt;label for=noVNC_setting_dynamic_quality_max&gt;Dynamic Quality Max:&lt;/label&gt; &lt;input id=noVNC_setting_dynamic_quality_max type=range min=0 max=9 value=9 onchange=&quot;noVNC_setting_dynamic_quality_max_output.value=value&quot;&gt;&lt;output id=noVNC_setting_dynamic_quality_max_output&gt;9&lt;/output&gt;&lt;li&gt;&lt;label for=noVNC_setting_treat_lossless&gt;Treat Lossless:&lt;/label&gt; &lt;input id=noVNC_setting_treat_lossless type=range min=0 max=9 value=7 onchange=&quot;noVNC_setting_treat_lossless_output.value=value&quot;&gt;&lt;output id=noVNC_setting_treat_lossless_output&gt;7&lt;/output&gt;&lt;li&gt;&lt;label for=noVNC_setting_framerate&gt;Frame Rate:&lt;/label&gt; &lt;input id=noVNC_setting_framerate type=number min=1 max=120 value=30&gt;&lt;li&gt;&lt;label for=noVNC_setting_jpeg_video_quality&gt;Video JPEG Quality:&lt;/label&gt; &lt;input id=noVNC_setting_jpeg_video_quality type=range min=0 max=9 value=5 onchange=&quot;noVNC_setting_jpeg_video_quality_output.value=value&quot;&gt;&lt;output id=noVNC_setting_jpeg_video_quality_output&gt;5&lt;/output&gt;&lt;li&gt;&lt;label for=noVNC_setting_webp_video_quality&gt;Video WEBP Quality:&lt;/label&gt; &lt;input id=noVNC_setting_webp_video_quality type=range min=0 max=9 value=5 onchange=&quot;noVNC_setting_webp_video_quality_output.value=value&quot;&gt;&lt;output id=noVNC_setting_webp_video_quality_output&gt;5&lt;/output&gt;&lt;li&