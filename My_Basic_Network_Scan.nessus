<plugin_publication_date>2012/01/17</plugin_publication_date>
<plugin_type>remote</plugin_type>
<risk_factor>Medium</risk_factor>
<script_version>1.6</script_version>
<solution>Purchase or generate a proper SSL certificate for this service.</solution>
<synopsis>The SSL certificate chain for this service ends in an unrecognized self-signed certificate.</synopsis>
